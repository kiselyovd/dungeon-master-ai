{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dungeon Master AI",
  "version": "0.1.0",
  "identifier": "com.kiselyovd.dungeonmasterai",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dungeon Master AI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/dmai-server", "binaries/mistralrs-server"]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/kiselyovd/dungeon-master-ai/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDQUZDOTVCRUUzQzAxQUMKUldTc0FUenVXOG12WEtkTkJlVVAwVnN2bWVJcmNBWXZ0cTd3UDlFMFdDWDZzcGswK0lBL3kxaWEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
